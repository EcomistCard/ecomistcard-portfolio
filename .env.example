# Live AI ChatBot — works with or without an API key.
# Without a key: hardcoded FAQ/portfolio replies (always responds).
# With a key: live AI (Groq free, or OpenAI paid).
# If the API fails, the bot automatically falls back to hardcoded FAQ replies.

# Force hardcoded replies only (no external API). Set to true to guarantee the bot always responds.
# USE_HARDCODED_CHAT=true

# FREE option (recommended): https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Optional: Groq model (default: llama-3.3-70b-versatile)
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Alternative: OpenAI (paid). Only used if GROQ_API_KEY is not set.
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Site URL (optional; used for contact link in chatbot)
# NEXT_PUBLIC_SITE_URL=https://cardlymartins.com
